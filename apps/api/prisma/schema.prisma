generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  fullName        String
  companyName     String?
  phone           String?
  phoneVerifiedAt DateTime?
  country         String?
  avatarDataUrl   String?
  promoCode       String?   @unique
  publicDescription String?
  profileDetails  Json?
  shippingAddress Json?
  billingAddress  Json?
  accountType     String    @default("individual")
  verificationLevel Int     @default(0)
  verificationStatus String @default("unverified")
  riskScore       Int       @default(0)
  mfaEnabled      Boolean   @default(false)
  cguAcceptedAt   DateTime?
  roles           String[]  @default(["user"])
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions Session[]
  quotes   Quote[]
  orders   Order[]
  payments Payment[]
  gerberUploads GerberUpload[]
  cookieConsents CookieConsent[]
  supportTickets SupportTicket[]
  adminAuditLogs AdminAuditLog[]
  adminAccesses AdminAccess[]
  notifications Notification[]
  explorerProjects ExplorerProject[]
  explorerProjectLikes ExplorerProjectLike[]
  explorerComments ExplorerComment[]
  followers UserFollow[] @relation("UserFollowers")
  following UserFollow[] @relation("UserFollowing")
  profileVerificationCodes ProfileVerificationCode[]
  passwordResetTokens PasswordResetToken[]
  accountDeletionFeedbacks AccountDeletionFeedback[]
  emailVerifications EmailVerification[]
  phoneVerifications PhoneVerification[]
  identityVerifications IdentityVerification[]
  businessVerifications BusinessVerification[]
  verificationDocuments VerificationDocument[]
  mfaFactors MfaFactor[]
  riskEvents RiskEvent[]
  notificationPreference NotificationPreference?
  pushSubscriptions PushSubscription[]
  userAuditLogs UserAuditLog[] @relation("UserAuditSubject")
  actorAuditLogs UserAuditLog[] @relation("UserAuditActor")
}

model CookieConsent {
  id          String   @id @default(uuid())
  userId      String
  version     String   @default("2026-05-07")
  necessary   Boolean  @default(true)
  analytics   Boolean  @default(false)
  preferences Boolean  @default(false)
  source      String   @default("web")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId])
}

model GerberUpload {
  id                String   @id @default(uuid())
  userId            String
  originalFilename  String
  sanitizedFilename String
  storageKey        String
  mimeType          String
  fileSizeBytes     Int
  status            String   @default("uploaded")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis GerberAnalysis?

  @@index([userId])
  @@index([storageKey])
}

model GerberAnalysis {
  id                String   @id @default(uuid())
  uploadId          String   @unique
  widthMm           Decimal? @db.Decimal(10, 2)
  heightMm          Decimal? @db.Decimal(10, 2)
  detectedLayers    Int?
  holesCount        Int      @default(0)
  hasSlots          Boolean  @default(false)
  boardAreaCm2      Decimal? @db.Decimal(12, 2)
  complexity        String   @default("unknown")
  parserConfidence  Decimal  @default(0) @db.Decimal(5, 4)
  units             String?
  outlineSource     String?
  copperLayerFiles  String[] @default([])
  drillFiles        String[] @default([])
  warnings          String[] @default([])
  rawSummary        Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  upload GerberUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([complexity])
}

model Quote {
  id                     String   @id @default(uuid())
  userId                 String
  productType            String
  gerberFileId           String
  bomFileId              String?
  cplFileId              String?
  layers                 Int
  lengthMm               Decimal  @db.Decimal(10, 2)
  widthMm                Decimal  @db.Decimal(10, 2)
  quantity               Int
  destinationCountryIso2 String
  shippingMode           String
  currency               String   @default("EUR")
  finalTotal             Decimal  @db.Decimal(12, 2)
  breakdown              Json
  configSnapshot          Json?
  validUntil             DateTime
  createdAt              DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
  pricingSnapshot PricingSnapshot?

  @@index([userId])
  @@index([validUntil])
}

model PricingSnapshot {
  id                     String   @id @default(uuid())
  quoteId                String   @unique
  supplier               String   @default("jlcpcb")
  supplierEstimatedPrice Decimal  @db.Decimal(12, 2)
  supplierRealPrice      Decimal? @db.Decimal(12, 2)
  bufferUsed             Decimal  @db.Decimal(6, 4)
  serviceFee             Decimal  @db.Decimal(12, 2)
  pcbClientPrice         Decimal  @db.Decimal(12, 2)
  shippingPrice          Decimal  @default(0) @db.Decimal(12, 2)
  totalClientPrice       Decimal  @db.Decimal(12, 2)
  currency               String   @default("EUR")
  bucketKey              String
  riskScore              Decimal  @db.Decimal(6, 4)
  confidence             String
  formulaVersion         String   @default("smart-buffer-v1")
  reasons                Json
  inputSnapshot          Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  adjustments BufferAdjustment[]

  @@index([bucketKey])
  @@index([supplier])
}

model BufferBucket {
  id               String   @id @default(uuid())
  bucketKey        String   @unique
  layersRange      String
  priceRange       String
  finish           String
  complexity       String
  quantityRange    String
  currentBuffer    Decimal  @db.Decimal(6, 4)
  minBuffer        Decimal  @default(1.0800) @db.Decimal(6, 4)
  maxBuffer        Decimal  @default(1.7000) @db.Decimal(6, 4)
  averageErrorRate Decimal  @default(0) @db.Decimal(8, 6)
  sampleCount      Int      @default(0)
  confidence       String   @default("low")
  riskFlag         Boolean  @default(false)
  lastErrorRate    Decimal? @db.Decimal(8, 6)
  lastAdjustedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  adjustments BufferAdjustment[]
}

model BufferAdjustment {
  id                String   @id @default(uuid())
  bucketId          String
  pricingSnapshotId String?
  quoteId           String?
  previousBuffer    Decimal  @db.Decimal(6, 4)
  nextBuffer        Decimal  @db.Decimal(6, 4)
  errorRate         Decimal  @db.Decimal(8, 6)
  direction         String
  reason            String
  metadata          Json?
  createdAt         DateTime @default(now())

  bucket BufferBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  pricingSnapshot PricingSnapshot? @relation(fields: [pricingSnapshotId], references: [id], onDelete: SetNull)

  @@index([bucketId])
  @@index([pricingSnapshotId])
  @@index([quoteId])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  email            String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  deviceFingerprint String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([refreshTokenHash])
  @@index([userId])
}

model EmailVerification {
  id          String    @id @default(uuid())
  userId      String
  email       String
  tokenHash   String
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PhoneVerification {
  id                      String    @id @default(uuid())
  userId                  String
  phone                   String
  provider                String
  providerVerificationSid String?
  codeHash                String?
  status                  String    @default("pending")
  attempts                Int       @default(0)
  expiresAt               DateTime?
  verifiedAt              DateTime?
  createdAt               DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@index([status])
}

model IdentityVerification {
  id                        String    @id @default(uuid())
  userId                    String
  provider                  String
  providerSessionId         String?
  providerClientReferenceId String?
  status                    String    @default("pending")
  documentType              String?
  country                   String?
  verifiedName              String?
  verifiedBirthDate         DateTime?
  mismatchReason            String?
  rawProviderResultJson     Json?
  startedAt                 DateTime  @default(now())
  completedAt               DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerSessionId])
  @@index([status])
}

model BusinessVerification {
  id                 String    @id @default(uuid())
  userId             String
  companyName        String
  registrationNumber String?
  taxId              String?
  companyAddressId   String?
  businessEmail      String?
  website            String?
  status             String    @default("pending")
  reviewedBy         String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model VerificationDocument {
  id               String   @id @default(uuid())
  userId           String
  verificationType String
  fileUrl          String
  fileType         String
  storageProvider  String
  status           String   @default("uploaded")
  uploadedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verificationType])
}

model MfaFactor {
  id              String    @id @default(uuid())
  userId          String
  type            String
  provider        String?
  secretEncrypted String?
  verifiedAt      DateTime?
  lastUsedAt      DateTime?
  enabled         Boolean   @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
}

model RiskEvent {
  id             String   @id @default(uuid())
  userId         String
  eventType      String
  riskScoreDelta Int
  metadataJson   Json?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
}

model UserAuditLog {
  id           String   @id @default(uuid())
  userId       String?
  actorId      String?
  eventType    String
  ipAddress    String?
  userAgent    String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  user User? @relation("UserAuditSubject", fields: [userId], references: [id], onDelete: SetNull)
  actor User? @relation("UserAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actorId])
  @@index([eventType])
}

model NotificationPreference {
  userId          String  @id
  emailEnabled    Boolean @default(true)
  pushEnabled     Boolean @default(true)
  smsEnabled      Boolean @default(false)
  whatsappEnabled Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id             String   @id @default(uuid())
  userId         String
  provider       String   @default("onesignal")
  externalId     String
  subscriptionId String
  deviceType     String?
  optedIn        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subscriptionId])
  @@index([userId])
}

model Order {
  id                           String    @id @default(uuid())
  orderNumber                  String    @unique
  userId                       String
  quoteId                      String
  destinationCountryIso2       String
  status                       String    @default("awaiting_payment")
  supplierReviewStatus         String    @default("not_sent")
  reviewAttemptCount           Int       @default(0)
  maxReviewAttempts            Int       @default(2)
  customerDecisionAfterRejection String?
  supplierFeedback             String?
  currentFileVersion           Int       @default(1)
  externalManufacturingPartner String?
  externalSupplierOrderId      String?
  carrierName                  String?
  trackingNumber               String?
  estimatedDeliveryAt          DateTime?
  paidAt                       DateTime?
  deliveredAt                  DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote    Quote     @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  payments Payment[]
  trackingEvents TrackingEvent[]
  orderFiles OrderFile[]
  technicalSpecFiles TechnicalSpecFile[]
  supplierReviews SupplierReview[]
  financeRecords FinanceRecord[]
  invoices Invoice[]
  productionJobs ProductionJob[]
  internationalShipments InternationalShipment[]
  localShipments LocalShipment[]
  mondaySyncLogs MondaySyncLog[]

  @@index([userId])
  @@index([status])
  @@index([supplierReviewStatus])
}

model OrderFile {
  id               String   @id @default(uuid())
  orderId          String
  fileType         String
  uploadId         String?
  fileUrl          String?
  fileVersion      Int
  isCurrentVersion Boolean  @default(true)
  uploadedAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, fileType, fileVersion])
  @@index([orderId, isCurrentVersion])
  @@index([uploadId])
}

model TechnicalSpecFile {
  id                 String   @id @default(uuid())
  orderId            String
  fileVersion        Int
  storageKey         String?
  payload            Json
  isCurrentVersion   Boolean  @default(true)
  createdAt          DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, fileVersion])
  @@index([orderId, isCurrentVersion])
}

model SupplierReview {
  id                      String    @id @default(uuid())
  orderId                 String
  attemptNumber           Int
  supplier                String
  supplierStatus          String
  supplierFeedback        String?
  externalReviewId        String?
  technicalPackageVersion Int
  reviewedAt              DateTime?
  createdAt               DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, attemptNumber, supplier, externalReviewId])
  @@index([orderId, attemptNumber])
  @@index([supplierStatus])
}

model FinanceRecord {
  id          String   @id @default(uuid())
  orderId     String
  type        String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("EUR")
  status      String   @default("recorded")
  metadata    Json?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([type])
}

model Invoice {
  id          String    @id @default(uuid())
  orderId     String
  invoiceNumber String @unique
  status      String    @default("issued")
  pdfUrl      String?
  issuedAt    DateTime  @default(now())
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ProductionJob {
  id          String    @id @default(uuid())
  orderId     String
  internalReference String @unique
  status      String    @default("created")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model InternationalShipment {
  id          String   @id @default(uuid())
  orderId     String
  status      String   @default("pending")
  carrierName String?
  trackingNumber String?
  cost        Decimal? @db.Decimal(12, 2)
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model LocalShipment {
  id          String   @id @default(uuid())
  orderId     String
  status      String   @default("pending")
  carrierName String?
  trackingNumber String?
  cost        Decimal? @db.Decimal(12, 2)
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model MondaySyncLog {
  id            String    @id @default(uuid())
  orderId       String?
  board         String
  itemId        String?
  operation     String
  sourceEventId String
  status        String    @default("pending")
  payload       Json?
  processedAt   DateTime?
  error         String?
  createdAt     DateTime  @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([board, operation, sourceEventId])
  @@index([orderId])
  @@index([status])
}

model MondayWebhookEvent {
  id              String    @id @default(uuid())
  providerEventId String    @unique
  board           String?
  boardId         String?
  itemId          String?
  eventType       String
  payload         Json
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime  @default(now())

  @@index([board])
  @@index([boardId])
  @@index([itemId])
  @@index([eventType])
  @@index([processedAt])
}

model TrackingEvent {
  id          String   @id @default(uuid())
  orderId     String
  status      String
  title       String
  description String?
  location    String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model Payment {
  id                String    @id @default(uuid())
  orderId           String
  userId            String
  provider          String
  providerPaymentId String?
  providerIntentId  String?
  status            String    @default("pending")
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("EUR")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  authorizedAt      DateTime?
  captureBefore     DateTime?
  succeededAt       DateTime?
  failedAt          DateTime?
  canceledAt        DateTime?

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@index([orderId])
  @@index([userId])
  @@index([providerIntentId])
  @@unique([provider, providerPaymentId])
}

model PaymentEvent {
  id              String    @id @default(uuid())
  paymentId       String?
  provider        String
  providerEventId String
  eventType       String
  payload         Json
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime  @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([paymentId])
}

model SupportTicket {
  id              String   @id @default(uuid())
  ticketNumber    String   @unique
  userId          String?
  requesterName   String?
  requesterEmail  String?
  category        String?
  orderId         String?
  subject         String
  message         String?
  attachmentName  String?
  status          String   @default("open")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model AdminAccess {
  id                    String    @id @default(uuid())
  userId                String
  professionalEmail     String    @unique
  accessRoles           String[]  @default(["admin"])
  isActive              Boolean   @default(true)
  personalCodeHash      String?
  personalCodeExpiresAt DateTime?
  setupCodeHash         String?
  setupCodeExpiresAt    DateTime?
  failedAttempts        Int       @default(0)
  lockedUntil           DateTime?
  lastVerifiedAt        DateTime?
  lastFailedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, professionalEmail])
  @@index([userId])
  @@index([professionalEmail])
  @@index([personalCodeExpiresAt])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([createdAt])
}

model ExplorerProject {
  id             String   @id @default(uuid())
  userId         String?
  authorName     String
  authorAvatarUrl String?
  title          String
  category       String
  summary        String
  description    String?
  tags           String[] @default([])
  imageUrl       String?
  attachmentName String?
  attachmentType String?
  repositoryUrl  String?
  status         String   @default("published")
  featured       Boolean  @default(false)
  viewsCount     Int      @default(0)
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  forksCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  likes ExplorerProjectLike[]
  comments ExplorerComment[]

  @@index([userId])
  @@index([status])
  @@index([featured])
  @@index([category])
  @@index([createdAt])
  @@index([likesCount])
}

model ExplorerProjectLike {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  actorKey  String
  createdAt DateTime @default(now())

  project ExplorerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, actorKey])
  @@index([projectId])
  @@index([userId])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model ExplorerComment {
  id          String   @id @default(uuid())
  projectId   String
  userId      String?
  authorName  String
  body        String
  status      String   @default("visible")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project ExplorerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ProfileVerificationCode {
  id        String   @id @default(uuid())
  userId    String
  action    String
  code      String
  metadata  Json?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AccountDeletionFeedback {
  id                  String   @id @default(uuid())
  userId              String?
  emailHash           String?
  reason              String
  details             Json?
  orderedBefore       String?
  improvementPriority String?
  keepReason          String?
  alternative         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([reason])
  @@index([alternative])
  @@index([createdAt])
}
