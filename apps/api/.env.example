OFFICIAL_CONTACT_EMAIL=contact.kendronics@gmail.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kendronics?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
ADMIN_EMAILS=kendostyve94@gmail.com
ADMIN_CODE_REQUIRED=true
ADMIN_CODE_SESSION_TTL_SECONDS=900
ADMIN_PRO_EMAIL_MAP=kendostyve94@gmail.com:contact.kendronics@gmail.com
FRONTEND_ORIGIN=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback

# Real SMTP delivery. For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=contact.kendronics@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=contact.kendronics@gmail.com
SMTP_HELO_DOMAIN=kendronics.com
VERIFICATION_CODE_EMAIL_REQUIRED=true
RESEND_FOR_OPERATIONAL_EMAIL=true

# Phone verification with Twilio Verify. Production cannot use PHONE_VERIFY_PROVIDER=dev.
PHONE_VERIFY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_CHANNEL=sms

# Real Stripe Checkout payments.
# Use sk_live_... for production/live payments and the whsec_... value from the
# Stripe webhook endpoint that posts to /api/payments/webhooks/stripe.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
STRIPE_IDENTITY_ENABLED=true
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_your-stripe-identity-webhook-signing-secret
STRIPE_IDENTITY_REQUIRE_SELFIE=true

# OneSignal push notifications. The frontend must use the same OneSignal app ID
# as NEXT_PUBLIC_ONESIGNAL_APP_ID.
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# ONESIGNAL_REQUIRED=true

# Mobile Money payments. Use "simulated" for local development, then switch to
# "cinetpay" or "paydunya" after the merchant account is validated.
MOBILE_MONEY_PROVIDER=simulated
MOBILE_MONEY_CURRENCY=XOF
MOBILE_MONEY_EUR_TO_LOCAL_RATE=655.957
MOBILE_MONEY_WEBHOOK_SECRET=replace-with-provider-webhook-secret
API_PUBLIC_ORIGIN=https://your-api.example.com

# CinetPay checkout.
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id

# PayDunya checkout.
PAYDUNYA_MODE=live
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_STORE_NAME=Kendronics

# PayPal Checkout Orders API. Use PAYPAL_ENV=live with live credentials in production.
# Kendronics creates PayPal orders with intent=AUTHORIZE, then captures only after
# technical file approval.
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=your-paypal-live-client-id
PAYPAL_CLIENT_SECRET=your-paypal-live-client-secret
PAYPAL_BRAND_NAME=Kendronics
# PAYPAL_REQUIRED=true

# PCB supplier pricing. Production uses the real supplier API and blocks quotes if
# live supplier pricing is unavailable.
PREFERRED_PCB_SUPPLIER=pcbway
JLCPCB_API_KEY=your-jlcpcb-api-key
JLCPCB_QUOTE_ENDPOINT=https://api.jlcpcb.com/replace-with-approved-quote-endpoint
JLCPCB_ORDER_ENDPOINT=https://api.jlcpcb.com/replace-with-approved-order-endpoint
PCBWAY_API_KEY=your-pcbway-api-key
PCBWAY_BALANCE_ENDPOINT=https://api-partner.pcbway.com/api/Account/QueryBalance
PCBWAY_QUOTE_ENDPOINT=https://api-partner.pcbway.com/api/Pcb/PcbQuotation
PCBWAY_ORDER_ENDPOINT=https://api-partner.pcbway.com/api/Pcb/PlaceOrder
REQUIRE_LIVE_SUPPLIER_PRICING=true

# Monday.com mirror dashboard. Backend/PostgreSQL remains the source of truth.
# Enable MONDAY_REQUIRED=true in production only after the API key and board IDs
# are configured, otherwise startup will block to avoid a false operational mode.
MONDAY_REQUIRED=true
MONDAY_API_KEY=your-monday-api-token
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_WEBHOOK_SECRET=replace-with-a-long-random-secret
MONDAY_BOARD_COMMANDES_ID=1234567890
MONDAY_BOARD_CHIFFRE_AFFAIRE_LIVE_ID=1234567891
MONDAY_BOARD_EN_PRODUCTION_ID=1234567892
MONDAY_BOARD_LOGISTICS_INTERNATIONAL_ID=1234567893
MONDAY_BOARD_LOGISTIQUE_LOCALE_ID=1234567894
MONDAY_BOARD_SUPPORT_CLIENTS_ID=1234567895
MONDAY_BOARD_REGISTRE_ACHATS_DEPENSES_ID=1234567896
MONDAY_BOARD_TRESORERIE_ID=1234567897
# Business keys used to find an existing Monday item before creating a new one.
# Defaults are shown here explicitly so production setup is auditable.
MONDAY_IDENTITY_FIELD_COMMANDES=orderNumber
MONDAY_IDENTITY_FIELD_CHIFFRE_AFFAIRE_LIVE=invoiceNumber
MONDAY_IDENTITY_FIELD_EN_PRODUCTION=internalReference
MONDAY_IDENTITY_FIELD_LOGISTICS_INTERNATIONAL=orderNumber
MONDAY_IDENTITY_FIELD_LOGISTIQUE_LOCALE=orderNumber
MONDAY_IDENTITY_FIELD_SUPPORT_CLIENTS=ticketNumber
MONDAY_IDENTITY_FIELD_REGISTRE_ACHATS_DEPENSES=expenseId
MONDAY_IDENTITY_FIELD_TRESORERIE=treasuryMonth
# Map backend payload fields to visible Monday column titles. The worker resolves
# titles to real technical column IDs automatically through Monday's API.
MONDAY_COLUMN_TITLE_MAP_COMMANDES={"orderNumber":"Id commande","customerName":"Nom Client","quoteId":"ID Devis","orderStatus":"Statut Commande","supplierOrderId":"ID Commande Fournisseur","supplierReviewStatus":"Statut Révision Fournisseur","supplier":"Fournisseur","gerberLink":"Lien Gerber","customerEmail":"Email Client","destinationCountry":"Pays Destination","shippingAddress":"Adresse Livraison","customerPhone":"Téléphone Client","specificationSummary":"Résumé Spécifications PCB"}
MONDAY_COLUMN_TITLE_MAP_EN_PRODUCTION={"internalReference":"Élément","supplier":"Fournisseur","customerName":"Nom Client","fabricationType":"Type Fabrication","productionStatus":"Statut Production","pcbFabricationStatus":"Statut Fabrication PCB","pcbQcStatus":"Statut QC PCB","supplierOrderId":"ID Commande Fournisseur","orderLink":"Lien Commande","assemblyRequired":"Assemblage Requis","smtStatus":"Statut SMT","destinationCountry":"Pays Destination"}
MONDAY_COLUMN_TITLE_MAP_LOGISTICS_INTERNATIONAL={"customerName":"Nom Client","customsImportStatus":"Statut Douane Import","supplier":"Fournisseur","destinationCity":"Ville Destination","trackingNumber":"Numéro Suivi","estimatedArrivalDate":"Date Estimée Arrivée","shippingDate":"Date Expédition","shippingMethod":"Méthode Expédition","threePlPartner":"Partenaire 3PL","supplierOrderId":"ID Commande Fournisseur","orderLink":"Lien Commande","pickupStatus":"Statut Enlèvement","customsExportStatus":"Statut Douane Export","warehouseStatus":"Statut Entrepôt","destinationCountry":"Pays Destination","trackingUrl":"URL Suivi","carrier":"Transporteur","packageCount":"Nombre de Colis","packageDimensions":"Dimensions Colis","packageWeight":"Poids Colis","internationalLogisticsStatus":"Statut Logistique Internationale","productionLink":"Lien Production"}
MONDAY_COLUMN_TITLE_MAP_LOGISTIQUE_LOCALE={"orderNumber":"Id commande","customerName":"Nom Client","localTrackingNumber":"Numéro Suivi Local","localCarrier":"Transporteur Local","localDeliveryStatus":"Statut Livraison Locale","estimatedDeliveryDate":"Date Livraison Estimée","localDepartureDate":"Date Départ Local","realDeliveryDate":"Date Livraison Réelle","recipientName":"Nom Réceptionnaire","localIncidentNotes":"Notes Incident Local","localIncidentStatus":"Statut Incident Local","localTrackingUrl":"URL Suivi Local","internationalLogisticsLink":"Lien Logistique Internationale","destinationCity":"Ville Destination","orderLink":"Lien Commande","shippingAddress":"Adresse Livraison","destinationCountry":"Pays Destination","deliveryProofLink":"Lien Preuve Livraison"}
MONDAY_COLUMN_TITLE_MAP_SUPPORT_CLIENTS={"ticketNumber":"Élément","customerName":"Nom Client","customerEmail":"Email Client","creationDate":"Date Création","category":"Catégorie Ticket","ticketStatus":"Statut Ticket","ticketPriority":"Priorité Ticket","firstResponseDeadline":"Deadline Première Réponse","resolutionDeadline":"Deadline Résolution","resolutionNotes":"Notes Résolution","resolutionType":"Type Résolution","orderLink":"Lien Commande","productionLink":"Lien Production","localDeliveryLink":"Lien Livraison Locale","internationalShippingLink":"Lien Expédition Internationale"}
MONDAY_COLUMN_TITLE_MAP_CHIFFRE_AFFAIRE_LIVE={"invoiceNumber":"Numéro Facture","orderNumber":"ID Commande","quoteId":"ID Devis","customerName":"CustomerName","customerCompany":"Entreprise Client","destinationCountry":"Pays Destination","currency":"Devise","paymentStatus":"PaymentStatus","quoteStatus":"QuoteStatus","paymentMethod":"Méthode Paiement","stripePaymentIntentId":"ID Intention Paiement Stripe","paymentDate":"Date Paiement","totalEstimatedPrice":"Prix Total Estimé","supplierEstimatedCost":"Coût Fournisseur Estimé","logisticsEstimatedCost":"Coût Logistique Estimé","customerPaidAmount":"Montant Payé Client","supplierExactCost":"Coût Fournisseur Exact","netMargin":"Marge Nette","estimatedKendronicsMargin":"Marge Kendronics Estimé","grossMargin":"GrossMargin","marginPercentage":"Pourcentage Marge","finalInvoicePdf":"FinalInvoicePDF","quotePdf":"PDF Devis","proformaInvoicePdf":"PDF Facture Proforma","invoiceStatus":"Statut Facture","supplierPaymentStatus":"Statut Paiement Fournisseur","threePlPaymentStatus":"ThreePLPaymentStatus"}
MONDAY_COLUMN_TITLE_MAP_REGISTRE_ACHATS_DEPENSES={"expenseId":"ID Depense","expenseDate":"Date Depense","createdBy":"Cree Par","expenseType":"Type Sortie","beneficiaryName":"Nom Beneficiaire","expenseCategory":"Categorie Depense","description":"Description","internalReference":"Reference Interne","amount":"Montant","currency":"Devise","paymentMethod":"Moyen Paiement","paymentStatus":"Statut Paiement","receiptLink":"Lien Recu","invoiceLink":"Lien Facture","approvedBy":"Approuve Par","approvalStatus":"Statut Approbation","orderLink":"Lien Commande","financeLink":"Lien Finance","treasuryLink":"Lien Tresorerie","costCenter":"Centre de Cout","financeNotes":"Notes Finance","accountingDocument":"Piece Comptable"}
MONDAY_COLUMN_TITLE_MAP_TRESORERIE={"treasuryMonth":"Mois","year":"Annee","revenueLink":"Lien Recettes","totalRevenue":"Total Recettes","expensesLink":"Lien Depenses","totalExpenses":"Total Depenses","monthlyResult":"Resultat Mensuel","previousMonthBalance":"Solde Mois Precedent","availableCash":"Tresorerie Disponible","cashForecast":"Prevision Tresorerie","treasuryNotes":"Notes Tresorerie"}
# You can also use MONDAY_COLUMN_MAP_* with technical column IDs directly.
# MONDAY_SYNC_DISABLED=true

# Private object storage for Gerber uploads. AWS S3 works directly.
# For Cloudflare R2 or another S3-compatible provider, also set S3_ENDPOINT.
S3_BUCKET=kendronics-private-uploads
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=your-storage-access-key
S3_SECRET_ACCESS_KEY=your-storage-secret-key
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
