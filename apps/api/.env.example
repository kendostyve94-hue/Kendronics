OFFICIAL_CONTACT_EMAIL=contact.kendronics@gmail.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kendronics?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
ADMIN_EMAILS=kendostyve94@gmail.com
ADMIN_CODE_REQUIRED=true
ADMIN_CODE_SESSION_TTL_SECONDS=900
ADMIN_PRO_EMAIL_MAP=kendostyve94@gmail.com:contact.kendronics@gmail.com
FRONTEND_ORIGIN=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback

# Real SMTP delivery. For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=contact.kendronics@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=contact.kendronics@gmail.com
SMTP_HELO_DOMAIN=kendronics.com

# Real Stripe Checkout payments.
# Use sk_live_... for production/live payments and the whsec_... value from the
# Stripe webhook endpoint that posts to /api/payments/webhooks/stripe.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret

# OneSignal push notifications. The frontend must use the same OneSignal app ID
# as NEXT_PUBLIC_ONESIGNAL_APP_ID.
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# ONESIGNAL_REQUIRED=true

# Mobile Money payments. Use "simulated" for local development, then switch to
# "cinetpay" or "paydunya" after the merchant account is validated.
MOBILE_MONEY_PROVIDER=simulated
MOBILE_MONEY_CURRENCY=XOF
MOBILE_MONEY_EUR_TO_LOCAL_RATE=655.957
MOBILE_MONEY_WEBHOOK_SECRET=replace-with-provider-webhook-secret
API_PUBLIC_ORIGIN=https://your-api.example.com

# CinetPay checkout.
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id

# PayDunya checkout.
PAYDUNYA_MODE=live
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_TOKEN=your-paydunya-token
PAYDUNYA_STORE_NAME=Kendronics

# PCB supplier pricing. Production uses the real supplier API and blocks quotes if
# live supplier pricing is unavailable.
PREFERRED_PCB_SUPPLIER=pcbway
JLCPCB_API_KEY=your-jlcpcb-api-key
JLCPCB_QUOTE_ENDPOINT=https://api.jlcpcb.com/replace-with-approved-quote-endpoint
JLCPCB_ORDER_ENDPOINT=https://api.jlcpcb.com/replace-with-approved-order-endpoint
PCBWAY_API_KEY=your-pcbway-api-key
PCBWAY_BALANCE_ENDPOINT=https://api-partner.pcbway.com/api/Account/QueryBalance
PCBWAY_QUOTE_ENDPOINT=https://api-partner.pcbway.com/api/Pcb/PcbQuotation
PCBWAY_ORDER_ENDPOINT=https://api-partner.pcbway.com/api/Pcb/PlaceOrder
REQUIRE_LIVE_SUPPLIER_PRICING=true

# Private object storage for Gerber uploads. AWS S3 works directly.
# For Cloudflare R2 or another S3-compatible provider, also set S3_ENDPOINT.
S3_BUCKET=kendronics-private-uploads
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=your-storage-access-key
S3_SECRET_ACCESS_KEY=your-storage-secret-key
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
